# ============================================================================
# Lasa Hub environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================================

# --- Database ---
# Get a free Postgres instance at https://neon.tech
# After creating a project, copy the "Connection string" from the dashboard.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- API server ---
NODE_ENV=development
PORT=8080
# Allow everything in dev; restrict in production.
CORS_ORIGIN=*
# A random long string. Used as a bearer token to gate /admin routes.
ADMIN_TOKEN=change-me-to-a-long-random-string
# If "true", /api/otp/send also returns the generated OTP in the response
# (useful for rural demo testing when SMS/WhatsApp is not reliable).
SHOW_OTP_IN_RESPONSE=true

# --- Google Gemini (for handwriting + voice parsing) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Twilio (for SMS OTP) ---
# Get credentials at https://console.twilio.com
# For real SMS you need a *purchased* Twilio phone number (e.g. +12025551234).
# For WhatsApp sandbox you'd use +14155238886 AND set TWILIO_CHANNEL=whatsapp.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# One of: sms | whatsapp
TWILIO_CHANNEL=sms
# Optional: public image URL for invoice media (production only).
# For localhost, leave empty and use rich text invoice messages.
INVOICE_MEDIA_BASE_URL=

# --- Frontend (Expo) ---
# Base URL of the API server. Leave blank to use http://localhost:8080
# Set this to your deployed API (e.g. https://lasa-api.onrender.com) for prod.
EXPO_PUBLIC_API_BASE=
