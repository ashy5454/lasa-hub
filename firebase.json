{
  "hosting": {
    "public": "apps/mobile/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api", "region": "us-central1" },
      { "source": "/assets/**", "destination": "/assets/**" },
      { "source": "/_expo/**", "destination": "/_expo/**" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      { "source": "**/*.ttf", "headers": [{ "key": "Content-Type", "value": "font/ttf" }] }
    ]
  },
  "functions": {
    "source": "functions-deploy",
    "runtime": "nodejs22"
  }
}
